#include <stdio.h>   // Bibliothèque standard pour entrées/sorties
#include <stdlib.h>  // Pour malloc et free (allocation dynamique)
#include <math.h>    // Pour la fonction sqrt (racine carrée)

// Définition d'une structure Point avec deux coordonnées entières
typedef struct {
    int x; // Coordonnée en abscisse
    int y; // Coordonnée en ordonnée
} Point;

// Fonction pour saisir un point au clavier
Point SaisirPoint() {
    Point p;
    printf("Entrez les coordonnées x et y : ");
    scanf("%d %d", &p.x, &p.y); // Lecture des deux entiers
    return p; // Retourne la structure remplie
}

// Fonction pour afficher un point sous la forme (x,y)
void AfficherPoint(Point p) {
    printf("(%d,%d)\n", p.x, p.y);
}

// Calcul de la distance d’un point à l’origine (version valeur)
double DistanceOrigine(Point p) {
    // Formule : sqrt(x² + y²)
    return sqrt(p.x * p.x + p.y * p.y);
}

// Calcul de la distance d’un point à l’origine (version pointeur)
double DistanceOriginePtr(Point *p) {
    // Utilisation de l’opérateur -> car p est un pointeur
    return sqrt(p->x * p->x + p->y * p->y);
}

// Fonction de tri d’un tableau de points par distance croissante
void TrierPoints(Point tab[], int n) {
    // Tri par échange simple (méthode des bulles améliorée)
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (DistanceOrigine(tab[i]) > DistanceOrigine(tab[j])) {
                // Échange des deux points
                Point tmp = tab[i];
                tab[i] = tab[j];
                tab[j] = tmp;
            }
        }
    }
}

int main() {
    int n;
    printf("Combien de points voulez-vous saisir ? ");
    scanf("%d", &n);

    // Version dynamique : allocation mémoire pour n points
    Point *tab = malloc(n * sizeof(Point));

    // Saisie des points
    for (int i = 0; i < n; i++) {
        tab[i] = SaisirPoint();
    }

    // Affichage des points saisis
    printf("\nPoints saisis :\n");
    for (int i = 0; i < n; i++) {
        AfficherPoint(tab[i]);
    }

    // Tri des points par distance
    TrierPoints(tab, n);

    // Affichage après tri
    printf("\nPoints tries par distance :\n");
    for (int i = 0; i < n; i++) {
        AfficherPoint(tab[i]);
    }

    // Libération de la mémoire allouée
    free(tab);
    return 0;
}
exercice2:
#include <stdio.h> // Pour printf et scanf

// Définition d'une structure Heure
typedef struct {
    int hh; // heures
    int mm; // minutes
    int ss; // secondes
} Heure;

// Conversion d'une heure en nombre total de secondes
int HeureEnSecondes(Heure h) {
    return h.hh * 3600 + h.mm * 60 + h.ss;
}

// Conversion d'un nombre de secondes en structure Heure
Heure SecondesEnHeure(int total) {
    Heure h;
    h.hh = total / 3600;     // Division entière pour obtenir les heures
    total %= 3600;           // Reste après avoir retiré les heures
    h.mm = total / 60;       // Division entière pour obtenir les minutes
    h.ss = total % 60;       // Reste pour les secondes
    return h;
}

// Addition de deux heures
Heure AdditionHeures(Heure h1, Heure h2) {
    int total = HeureEnSecondes(h1) + HeureEnSecondes(h2);
    return SecondesEnHeure(total);
}

// Différence entre deux heures
Heure DifferenceHeures(Heure h1, Heure h2) {
    int diff = HeureEnSecondes(h1) - HeureEnSecondes(h2);
    if (diff < 0) diff = -diff; // Valeur absolue
    return SecondesEnHeure(diff);
}

// Affichage d’une heure au format hh:mm:ss
void AfficherHeure(Heure h) {
    printf("%02d:%02d:%02d\n", h.hh, h.mm, h.ss);
}

int main() {
    Heure h1, h2; // Déclaration de deux variables de type Heure

    // Saisie de la première heure
    printf("Entrer la 1ère heure (hh mm ss) : ");
    scanf("%d %d %d", &h1.hh, &h1.mm, &h1.ss);

    // Saisie de la deuxième heure
    printf("Entrer la 2ème heure (hh mm ss) : ");
    scanf("%d %d %d", &h2.hh, &h2.mm, &h2.ss);

    // Affichage des heures saisies
    printf("Heure 1 : "); AfficherHeure(h1);
    printf("Heure 2 : "); AfficherHeure(h2);

    // Calcul et affichage de la somme
    Heure somme = AdditionHeures(h1, h2);
    printf("Somme : "); AfficherHeure(somme);

    // Calcul et affichage de la différence
    Heure diff = DifferenceHeures(h1, h2);
    printf("Différence : "); AfficherHeure(diff);

    return 0;
}
