#include <stdio.h>

// Fonction qui retourne l'indice de la première occurrence du minimum
int indiceMin(int tab[], int n) {
    int min = tab[0];     // On suppose que le premier élément est le minimum
    int indice = 0;       // Indice du minimum actuel

    for (int i = 1; i < n; i++) {
        if (tab[i] < min) {
            min = tab[i]; // Nouveau minimum trouvé
            indice = i;   // On met à jour son indice
        }
    }
    return indice; // Retourne l'indice de la première occurrence
}

int main() {
    int tab[] = {5,2,4,2,1,7,9,4,1,1};
    int n = sizeof(tab)/sizeof(tab[0]);

    int indice = indiceMin(tab, n);
    printf("Indice de la première occurrence du minimum = %d\n", indice);

    return 0;
}
