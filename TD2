#include <stdio.h>

// Version récursive simple : a^i
int puissanceSimple(int a, int i) {
    if (i == 0) return 1;
    return a * puissanceSimple(a, i - 1);
}

// Version exponentiation rapide
int puissanceRapide(int a, int i) {
    if (i == 0) return 1;
    if (i % 2 == 0) {
        int demi = puissanceRapide(a, i/2);
        return demi * demi;
    } else {
        return a * puissanceRapide(a, i - 1);
    }
}

// Somme Σ a^i de i=0 à n
int somme(int a, int n) {
    if (n == 0) return 1;
    return puissanceSimple(a, n) + somme(a, n - 1);
}

int main() {
    printf("Puissance simple 2^5 = %d\n", puissanceSimple(2,5));
    printf("Puissance rapide 2^5 = %d\n", puissanceRapide(2,5));
    printf("Somme Σ 2^i pour i=0..5 = %d\n", somme(2,5));
    return 0;
}
