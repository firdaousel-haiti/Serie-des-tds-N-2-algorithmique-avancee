#include <stdio.h>

// Fonction qui calcule le MiniMax d'une matrice n x m
int MiniMax(int mat[][100], int n, int m) {
    int minimax = 999999; // Valeur très grande pour initialiser

    for (int i = 0; i < n; i++) {
        int maxLigne = mat[i][0]; // Max de la ligne i
        for (int j = 1; j < m; j++) {
            if (mat[i][j] > maxLigne)
                maxLigne = mat[i][j];
        }
        // On compare avec le minimum global
        if (maxLigne < minimax)
            minimax = maxLigne;
    }
    return minimax;
}

int main() {
    int mat[3][100] = {
        {5, 8, 2},
        {7, 6, 9},
        {4, 3, 10}
    };

    printf("MiniMax = %d\n", MiniMax(mat, 3, 3));
    return 0;
}
